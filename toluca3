<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Historia del Toluca</title>

<style>
body{
    font-family: Arial, sans-serif;
    margin:0;
    background:#f5f5f5;
    color:#333;
}

header{
    background:#c00000;
    color:white;
    text-align:center;
    padding:40px 20px;
}

main{
    max-width:1000px;
    margin:auto;
    padding:20px;
}

section{
    background:white;
    margin:20px 0;
    padding:20px;
    border-radius:10px;
    box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

h2{
    color:#c00000;
}

.timeline{
    border-left:4px solid #c00000;
    padding-left:20px;
}

footer{
    text-align:center;
    background:#222;
    color:white;
    padding:15px;
}
